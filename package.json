{
	"name": "kitchen-software",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:migrate:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0001_init.sql",
		"db:migrate:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0001_init.sql",
		"db:migrate:content:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0002_content_lists.sql",
		"db:migrate:content:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0002_content_lists.sql",
		"db:migrate:preplists:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0003_preplist_amounts.sql",
		"db:migrate:preplists:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0003_preplist_amounts.sql",
		"db:repair:listsections:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0004_fix_list_sections_unique.sql",
		"db:repair:listsections:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0004_fix_list_sections_unique.sql",
		"db:repair:auth:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0005_auth_schema_repair.sql",
		"db:repair:auth:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0005_auth_schema_repair.sql",
		"db:repair:hard:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0006_hard_repair_core.sql",
		"db:repair:hard:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0006_hard_repair_core.sql",
		"db:seed:preplists:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0007_preplist_seed_only.sql",
		"db:seed:preplists:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0007_preplist_seed_only.sql",
		"db:migrate:tasksrecipes:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0008_todos_recipes.sql",
		"db:migrate:tasksrecipes:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0008_todos_recipes.sql",
		"db:migrate:todoassign:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0009_todo_assignments.sql",
		"db:migrate:todoassign:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0009_todo_assignments.sql",
		"db:migrate:nodenames:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0010_sensor_nodes.sql",
		"db:migrate:nodenames:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0010_sensor_nodes.sql",
		"db:migrate:whiteboardmod:local": "npx wrangler d1 execute kitchen --local --file=./migrations/0011_whiteboard_moderation.sql",
		"db:migrate:whiteboardmod:remote": "npx wrangler d1 execute kitchen --remote --file=./migrations/0011_whiteboard_moderation.sql",
		"lint": "prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.48.2",
		"svelte-check": "^4.3.5",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
